    "fmt": "forge fmt",
    "fmt:check": "forge fmt --check",
    "clean": "forge clean",
    "install:deps": "forge install foundry-rs/forge-std@v1.9.6 && forge install OpenZeppelin/openzeppelin-contracts@v5.2.0 && forge install smartcontractkit/chainlink-brownie-contracts@1.3.0"
  }
}
