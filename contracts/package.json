{
  "name": "@verifiable-random-game/contracts",
  "version": "1.0.0",
  "private": true,
  "description": "Solidity smart contracts for verifiable-random-game (Foundry)",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vv",
    "test:coverage": "forge coverage --report summary",
